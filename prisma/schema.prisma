generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  password  String
  telefono  String?
  ciudad    String   @default("Ibagué")
  rol       Rol      @default(CLIENTE)
  activo            Boolean   @default(true)
  emailVerificado   Boolean   @default(false)
  emailVerifToken   String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  refreshToken      String?
  refreshTokenExp   DateTime?
  referralCode      String?   @unique  // e.g. "DANIE2847"
  referredById      String?            // userId of referrer
  referredBy        User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals         User[]    @relation("Referrals")
  // UTM attribution — captured at registration
  utmSource         String?   // e.g. "facebook", "google", "tiktok", "whatsapp"
  utmMedium         String?   // e.g. "cpc", "social", "email", "organic"
  utmCampaign       String?   // e.g. "spring_2025", "referidos_x2"
  utmContent        String?   // e.g. "banner_v1", "story_15s"
  utmTerm           String?   // keyword (Google Ads)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relaciones
  providerProfile       ProviderProfile?
  bookingsComoCliente   Booking[] @relation("ClienteBookings")
  reviewsEscritas       Review[]  @relation("ClienteReviews")
  favoritos             Favorito[] @relation("ClienteFavoritos")
  notificaciones        Notificacion[]
  disputas              Disputa[]
  mensajesEnviados      MensajeChat[] @relation("MensajesEnviados")
  tagAsignaciones       CrmTagAsignacion[]
  pushSubscriptions     PushSubscription[]
  loyaltyAccount        LoyaltyAccount?
}

model Notificacion {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipo      String   // booking_status | booking_new | review_new | pago_recibido | recurrencia_creada
  titulo    String
  mensaje   String
  leida     Boolean  @default(false)
  data      Json?    // { bookingId, estado, proveedorNombre, clienteNombre, etc. }
  createdAt DateTime @default(now())

  @@index([userId, leida])
  @@index([userId, createdAt(sort: Desc)])
}

enum Rol {
  CLIENTE
  PROVEEDOR
  ADMIN
}

model ProviderUnavailability {
  id          String          @id @default(cuid())
  providerId  String
  provider    ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  fechaInicio DateTime
  fechaFin    DateTime
  motivo      String?         // "vacaciones" | "enfermedad" | "otro"
  createdAt   DateTime        @default(now())

  @@index([providerId, fechaInicio])
  @@index([fechaInicio, fechaFin])
}

model ProviderProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  bio           String?
  servicios     String[] // ["aseo", "jardineria", "plomeria"]
  tarifaPorHora Float    @default(25000) // en COP
  ciudades      String[] @default(["Ibagué"])
  calificacion  Float    @default(0)
  totalReviews  Int      @default(0)
  verificado    Boolean  @default(false)
  disponible    Boolean  @default(true)
  aniosExperiencia  Int?      // años de experiencia declarados
  cedulaUrl         String?
  cedulaStatus      String    @default("sin_enviar") // sin_enviar | pendiente | aprobado | rechazado
  cedulaNota        String?   // razón de rechazo (opcional)
  // ── Nuevas features avanzadas ──────────────────────────────────────────
  horario           Json?     // {"lun":{"activo":true,"inicio":"08:00","fin":"18:00"},...}
  portfolioUrls     String[]  // URLs de fotos de trabajos realizados
  instantBooking    Boolean   @default(false) // salta PENDIENTE → CONFIRMADO automáticamente
  reservasCompletadas Int     @default(0)     // contador desnormalizado de COMPLETADO
  tiempoRespuestaH  Float?    // promedio de horas hasta confirmar (actualizado por cron)
  totalViews        Int       @default(0)     // vistas al perfil público (incrementado en GET /providers/:id)
  tasaAceptacion    Float?    // % bookings confirmados (actualizado por cron diario)
  embedding         Unsupported("vector(1536)")?  // OpenAI text-embedding-3-small
  // ── Background check & voice onboarding ────────────────────────────────
  backgroundScore   Int?      // 0-100 composite score from voice interview + cedula
  backgroundData    Json?     // {references, workHistory, selfDeclaration, interviewAnswers}
  backgroundStatus  String    @default("pendiente") // pendiente | aprobado | rechazado | en_revision
  voiceOnboardingAt DateTime? // timestamp when voice interview was completed
  // ── Service packages ─────────────────────────────────────────────────────
  paquetes          Json?     // [{id,nombre,descripcion,precio,duracionHoras,incluye}]
  // ── Cobros / payout info ─────────────────────────────────────────────────
  metodoCobro       String?   // Nequi | Daviplata | Bancolombia | Davivienda | Nequi | PSE
  numeroCobro       String?   // phone number or account number
  titularCobro      String?   // account holder name (may differ from user.nombre)
  bancoCobro        String?   // bank name if metodoCobro is bank account
  tipoCuentaCobro   String?   // AHORROS | CORRIENTE
  createdAt         DateTime  @default(now())

  bookings       Booking[]
  reviews        Review[]
  favoritos      Favorito[]
  location       ProviderLocation?
  pagos          Pago[]
  unavailability ProviderUnavailability[]
}

// ── Project Management ────────────────────────────────────────────────────
model Project {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  estado      String   @default("planificacion") // planificacion | activo | pausado | completado | cancelado
  prioridad   String   @default("media")         // critica | alta | media | baja
  tipo        String   @default("interno")       // interno | producto | cliente | infraestructura | investigacion
  fechaInicio DateTime?
  fechaFin    DateTime?
  presupuesto Float?
  progreso    Int      @default(0)               // 0-100 auto-calculated from tasks
  owner       String?
  equipo      String[]
  tags        String[]
  color       String   @default("#0ABFBC")
  aiPlan      Json?    // full AI-generated project plan
  aiRisks     Json?    // AI risk register
  aiSummary   String?  // latest AI status summary
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks      ProjectTask[]
  milestones ProjectMilestone[]
  comments   ProjectComment[]

  @@index([estado, prioridad])
}

model ProjectTask {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  titulo       String
  descripcion  String?
  columna      String   @default("backlog") // backlog | todo | in_progress | review | done | blocked
  prioridad    String   @default("media")
  asignado     String?
  puntos       Int?     // story points
  etiquetas    String[]
  fechaVence   DateTime?
  estimacion   String?  // AI-estimated effort string
  subtareas    Json?    // [{id, texto, done}]
  dependencias String[] // other task IDs
  aiNotas      String?
  orden        Int      @default(0)
  bloqueadoPor String?  // reason why blocked
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId, columna])
  @@index([asignado])
}

model ProjectMilestone {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nombre      String
  fecha       DateTime
  estado      String   @default("pendiente") // pendiente | en_riesgo | completado
  descripcion String?
  createdAt   DateTime @default(now())

  @@index([projectId])
}

model ProjectComment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  autor     String
  contenido String
  tipo      String   @default("comentario") // comentario | decision | blocker | ai_insight
  createdAt DateTime @default(now())
}

// ── HR Models ─────────────────────────────────────────────────────────────
model Employee {
  id          String   @id @default(cuid())
  nombre      String
  email       String   @unique
  cargo       String
  dept        String
  tipo        String   @default("TIEMPO_COMPLETO") // TIEMPO_COMPLETO | MEDIO_TIEMPO | CONTRATISTA | PASANTE
  salario     Float    @default(0)
  estado      String   @default("ACTIVO") // ACTIVO | INACTIVO | LICENCIA
  inicio      DateTime @default(now())
  performance String?  // EXCELENTE | BUENO | REGULAR | BAJO
  skills      String[]
  vacaciones  Int      @default(15)
  telefono    String?
  foto        String?
  nivelSalarial String? // junior | mid | senior | lead | director
  reportaA    String?  // Employee.id
  notas       String?  // private HR notes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews     PerformanceReview[]
  ptoRequests PtoRequest[]

  @@index([dept, estado])
}

model JobPosition {
  id          String   @id @default(cuid())
  cargo       String
  dept        String
  prioridad   String   @default("MEDIA") // ALTA | MEDIA | BAJA
  estado      String   @default("ABIERTA") // ABIERTA | SCREENING | ENTREVISTAS | OFERTA | CERRADA
  descripcion String?
  requisitos  String[]
  salarioMin  Float?
  salarioMax  Float?
  ubicacion   String   @default("Remoto/Ibagué")
  aiBrief     Json?    // full AI-generated JD {resumen, responsabilidades, requisitos, beneficios}
  aiQuestions Json?    // AI interview questions per stage
  candidatos  Int      @default(0)
  publicadaEn String[] // ["LinkedIn","Computrabajo","HojaDeVida"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PerformanceReview {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  periodo      String   // "2025-Q2"
  tipo         String   @default("trimestral") // trimestral | anual | pip | 360
  score        String?  // EXCELENTE | BUENO | REGULAR | BAJO
  metasAlcanzadas Float?
  fortalezas   String?
  areasMejora  String?
  comentario   String?
  aiBorrador   String?  // AI-generated draft
  revisorNombre String?
  estado       String   @default("borrador") // borrador | completada | firmada
  createdAt    DateTime @default(now())
}

model PtoRequest {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  tipo       String   // VACACIONES | LICENCIA | INCAPACIDAD | PERMISO
  desde      DateTime
  hasta      DateTime
  dias       Int
  motivo     String?
  estado     String   @default("PENDIENTE") // PENDIENTE | APROBADA | RECHAZADA
  aprobadoPor String?
  createdAt  DateTime @default(now())

  @@index([employeeId, estado])
}

model HrPulse {
  id        String   @id @default(cuid())
  titulo    String
  preguntas Json     // [{id, texto, tipo:"escala|texto|opcion", opciones?:[]}]
  respuestas Json?   // [{empleadoId, respuestas:[{id, valor}], createdAt}]
  analisis  String?  // AI narrative
  score     Float?   // 0-10 overall score
  temas     Json?    // [{tema, sentimiento, menciones}]
  estado    String   @default("borrador") // borrador | enviada | cerrada
  createdAt DateTime @default(now())
}

// ── Ad Campaigns (cross-platform tracker) ─────────────────────────────────
model AdCampaign {
  id           String   @id @default(cuid())
  nombre       String
  plataforma   String   // meta | google | tiktok | multi
  objetivo     String   // awareness | trafico | conversiones | leads
  estado       String   @default("borrador") // borrador | activa | pausada | terminada | error
  externalId   String?  // platform campaign ID returned by API
  presupuestoTotal Float @default(0)
  presupuestoDiario Float?
  gastado      Float    @default(0)
  impresiones  Int      @default(0)
  clicks       Int      @default(0)
  conversiones Int      @default(0)
  cpa          Float?
  ctr          Float?
  roas         Float?
  aiScore      Int?     // 0-100 AI health score
  aiNotas      String?  // latest AI observation
  copy         Json?    // { facebook, instagram, tiktok, google, whatsapp }
  targeting    Json?    // { edad, genero, ciudades, intereses }
  creativos    Json?    // { imagenes, videos }
  metadata     Json?    // raw platform response
  startDate    DateTime?
  endDate      DateTime?
  creadoPorIA  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  automations  AdAutomationLog[]

  @@index([plataforma, estado])
  @@index([createdAt(sort: Desc)])
}

// ── Automation rules ───────────────────────────────────────────────────────
model AdAutomation {
  id          String   @id @default(cuid())
  nombre      String
  activa      Boolean  @default(true)
  plataforma  String   @default("todas") // meta | google | tiktok | todas
  condicion   String   // cpa_mayor | ctr_menor | roas_menor | gasto_diario_mayor | impresiones_bajas
  valor       Float
  accion      String   // pausar | activar | aumentar_presupuesto | reducir_presupuesto | alertar
  parametro   Float?   // extra param (e.g. % change)
  disparos    Int      @default(0)
  ultimoDisparo DateTime?
  createdAt   DateTime @default(now())
  logs        AdAutomationLog[]
}

model AdAutomationLog {
  id           String       @id @default(cuid())
  automationId String
  automation   AdAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  campaignId   String?
  campaign     AdCampaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  accionTomada String
  detalles     String?
  createdAt    DateTime     @default(now())
}

// ── Payment records ────────────────────────────────────────────────────────
model Pago {
  id           String     @id @default(cuid())
  bookingId    String
  booking      Booking    @relation(fields: [bookingId], references: [id])
  proveedorId  String?
  proveedor    ProviderProfile? @relation(fields: [proveedorId], references: [id])
  tipo         TipoPago
  monto        Float      // amount in COP
  estado       EstadoPago @default(PENDIENTE)
  referencia   String?    // MercadoPago payment ID or bank transfer ref
  metodo       String?    // Nequi, Daviplata, Bancolombia, etc.
  notas        String?
  procesadoPor String?    // admin userId who processed the payout
  fechaPago    DateTime?  // when the money actually moved
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([bookingId])
  @@index([tipo, estado])
  @@index([proveedorId, estado])
}

enum TipoPago {
  CLIENTE_RECIBIDO     // Payment received from client via MercadoPago
  PROVEEDOR_PENDIENTE  // Money owed to provider (booking completed, dispute window open)
  PROVEEDOR_PAGADO     // Money sent to provider (85% of booking total)
  REEMBOLSO_CLIENTE    // Refund to client (dispute won by client)
}

enum EstadoPago {
  PENDIENTE
  EN_PROCESO
  COMPLETADO
  FALLIDO
}

model ProviderLocation {
  id         String          @id @default(cuid())
  providerId String          @unique
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  lat        Float
  lng        Float
  activo     Boolean         @default(true)
  updatedAt  DateTime        @updatedAt

  @@index([providerId])
}

model Booking {
  id              String          @id @default(cuid())
  clienteId       String
  cliente         User            @relation("ClienteBookings", fields: [clienteId], references: [id])
  proveedorId     String
  proveedor       ProviderProfile @relation(fields: [proveedorId], references: [id])
  tipoServicio    String
  descripcion     String?
  fechaServicio   DateTime
  duracionHoras   Float           @default(2)
  precioTotal     Float
  comisionDutyJoy Float
  estado          EstadoBooking   @default(PENDIENTE)
  recurrencia     Recurrencia     @default(UNICA)     // frecuencia de repetición
  bookingPadreId  String?         // apunta al booking original (null si es el original)
  bookingPadre    Booking?        @relation("RecurrenciaBookings", fields: [bookingPadreId], references: [id])
  bookingsHijos   Booking[]       @relation("RecurrenciaBookings")
  motivoCancelacion String?       // razón de cancelación (opcional)
  fotos           String[]        // post-job photo URLs/base64 uploaded by provider
  // ── Service start code ────────────────────────────────────────────────────
  startCode         String?       // 6-digit code shown to client, entered by provider
  startCodeExpiry   DateTime?     // valid for 30 min after generation
  startCodeAttempts Int           @default(0)  // failed provider attempts (max 3)
  startCodeUsedAt   DateTime?     // set when provider verifies successfully
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  review    Review?
  disputas  Disputa[]
  mensajes  MensajeChat[]
  pagos     Pago[]
}

enum Recurrencia {
  UNICA
  SEMANAL
  QUINCENAL
  MENSUAL
}

enum EstadoBooking {
  PENDIENTE
  CONFIRMADO
  EN_PROGRESO
  COMPLETADO
  CANCELADO
}

model Review {
  id           String          @id @default(cuid())
  bookingId    String          @unique
  booking      Booking         @relation(fields: [bookingId], references: [id])
  clienteId    String
  cliente      User            @relation("ClienteReviews", fields: [clienteId], references: [id])
  proveedorId  String
  proveedor    ProviderProfile @relation(fields: [proveedorId], references: [id])
  calificacion        Int      // 1 a 5
  comentario          String?
  respuestaProveedor  String?  // respuesta pública del proveedor a la reseña
  // ── Fraud detection ──────────────────────────────────────────────────────
  fraudScore          Float?   // 0.0 (clean) → 1.0 (likely fake)
  fraudFlags          String[] // detected patterns, e.g. ["texto_generico","primera_resena"]
  fraudCheckedAt      DateTime?
  fraudOculta         Boolean  @default(false) // admin hidó esta reseña
  createdAt           DateTime @default(now())
}

model Disputa {
  id              String   @id @default(cuid())
  bookingId       String
  booking         Booking  @relation(fields: [bookingId], references: [id])
  clienteId       String
  cliente         User     @relation(fields: [clienteId], references: [id])
  mensaje         String
  estado          String   @default("abierta")  // abierta | en_revision | resuelta | cerrada
  resolucion      String?  // nota de resolución por el admin
  resueltaPorId   String?  // userId del admin que resolvió
  // ── AI auto-resolution ──────────────────────────────────────────────────
  aiVeredicto     String?  // favor_cliente | favor_proveedor | compromiso
  aiConfianza     Float?   // 0.0 – 1.0
  aiRazonamiento  String?  // explicación del modelo
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([estado])
  @@index([bookingId])
  @@index([clienteId])
}

model MensajeChat {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  autorId     String
  autor       User     @relation("MensajesEnviados", fields: [autorId], references: [id])
  contenido   String
  leido       Boolean  @default(false)
  tipo        String   @default("texto") // texto | imagen | sistema
  createdAt   DateTime @default(now())

  @@index([bookingId, createdAt(sort: Asc)])
  @@index([autorId])
}

model Favorito {
  id          String          @id @default(cuid())
  clienteId   String
  cliente     User            @relation("ClienteFavoritos", fields: [clienteId], references: [id])
  proveedorId String
  proveedor   ProviderProfile @relation(fields: [proveedorId], references: [id])
  createdAt   DateTime        @default(now())

  @@unique([clienteId, proveedorId])
}

// ── CRM Tags ──────────────────────────────────────────────────────────────
model CrmTag {
  id          String   @id @default(cuid())
  nombre      String   @unique
  color       String   @default("#0ABFBC")
  descripcion String?
  createdAt   DateTime @default(now())

  asignaciones CrmTagAsignacion[]
}

model CrmTagAsignacion {
  id          String   @id @default(cuid())
  tagId       String
  tag         CrmTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asignadoPor String   // admin userId
  createdAt   DateTime @default(now())

  @@unique([tagId, userId])
  @@index([userId])
  @@index([tagId])
}

// ── Web Push Subscriptions ────────────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Loyalty / Puntos ─────────────────────────────────────────────────────
model LoyaltyAccount {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  puntos         Int      @default(0)
  nivel          String   @default("bronce") // bronce|plata|oro|platino
  totalGanados   Int      @default(0)
  totalCanjeados Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transacciones  LoyaltyTransaction[]

  @@index([userId])
  @@index([nivel])
}

model LoyaltyTransaction {
  id          String         @id @default(cuid())
  accountId   String
  account     LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  puntos      Int
  tipo        String         // booking_completado|resena|referido|primera_reserva|canjeado|bonus|recurrencia
  descripcion String?
  bookingId   String?
  cuponId     String?
  createdAt   DateTime       @default(now())

  @@index([accountId, createdAt(sort: Desc)])
}

// ── Coupons ───────────────────────────────────────────────────────────────
model Cupon {
  id          String   @id @default(cuid())
  codigo      String   @unique
  tipo        String   @default("porcentaje") // porcentaje | fijo
  valor       Float
  descripcion String?
  activo      Boolean  @default(true)
  usos        Int      @default(0)
  maxUsos     Int?
  montoMinimo Float?
  expira      DateTime?
  creadoPor   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([codigo])
  @@index([activo])
}

// ── Automation Engine ─────────────────────────────────────────────────────
model AutomationRule {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  activa      Boolean  @default(true)
  tipo        String   // churn_prevention|quality_coaching|review_request|no_show_prevention|client_reactivation|fraud_quarantine|dispute_prevention|provider_welcome|revenue_anomaly|sla_escalation
  categoria   String   @default("operacional") // operacional|retencion|calidad|fraude|financiero
  trigger     Json     // { evento, condicion, umbral }
  accion      Json     // { tipo, payload, canal }
  schedule    String   @default("diario")      // diario|cada_hora|semanal|evento
  ejecuciones Int      @default(0)
  exitos      Int      @default(0)
  errores     Int      @default(0)
  afectados   Int      @default(0)
  ultimaEjecucion   DateTime?
  proximaEjecucion  DateTime?
  creadoPorIA Boolean  @default(false)
  aiRationale String?  // why AI suggested this
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs AutomationLog[]

  @@index([activa, tipo])
  @@index([categoria])
}

model AutomationLog {
  id          String         @id @default(cuid())
  ruleId      String
  rule        AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  estado      String         @default("exitoso") // exitoso|fallido|saltado|parcial
  afectados   Int            @default(0)
  detalles    Json?
  error       String?
  duracionMs  Int?
  createdAt   DateTime       @default(now())

  @@index([ruleId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

// ── Security: Audit Trail ─────────────────────────────────────────────────
model AuditLog {
  id           String   @id @default(cuid())
  userId       String?  // who did it (null = system/webhook)
  accion       String   // "user_role_change" | "pago_procesado" | "booking_cancelado" | "admin_login" | ...
  entidad      String?  // "User" | "Booking" | "Pago" | ...
  entidadId    String?  // the affected record id
  valorAntes   Json?    // old value snapshot
  valorDespues Json?    // new value snapshot
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([accion, createdAt(sort: Desc)])
  @@index([entidad, entidadId])
  @@index([createdAt(sort: Desc)])
}

// ── Security: Login Attempts (brute-force tracking) ───────────────────────
model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String
  exitoso   Boolean  @default(false)
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email, createdAt(sort: Desc)])
  @@index([ip, createdAt(sort: Desc)])
}
