generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  password  String
  telefono  String?
  ciudad    String   @default("Ibagué")
  rol       Rol      @default(CLIENTE)
  activo            Boolean   @default(true)
  emailVerificado   Boolean   @default(false)
  emailVerifToken   String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  refreshToken      String?
  refreshTokenExp   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relaciones
  providerProfile       ProviderProfile?
  bookingsComoCliente   Booking[] @relation("ClienteBookings")
  reviewsEscritas       Review[]  @relation("ClienteReviews")
  favoritos             Favorito[] @relation("ClienteFavoritos")
  notificaciones        Notificacion[]
  disputas              Disputa[]
  mensajesEnviados      MensajeChat[] @relation("MensajesEnviados")
  tagAsignaciones       CrmTagAsignacion[]
  pushSubscriptions     PushSubscription[]
}

model Notificacion {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipo      String   // booking_status | booking_new | review_new | pago_recibido | recurrencia_creada
  titulo    String
  mensaje   String
  leida     Boolean  @default(false)
  data      Json?    // { bookingId, estado, proveedorNombre, clienteNombre, etc. }
  createdAt DateTime @default(now())

  @@index([userId, leida])
  @@index([userId, createdAt(sort: Desc)])
}

enum Rol {
  CLIENTE
  PROVEEDOR
  ADMIN
}

model ProviderProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  bio           String?
  servicios     String[] // ["aseo", "jardineria", "plomeria"]
  tarifaPorHora Float    @default(25000) // en COP
  ciudades      String[] @default(["Ibagué"])
  calificacion  Float    @default(0)
  totalReviews  Int      @default(0)
  verificado    Boolean  @default(false)
  disponible    Boolean  @default(true)
  aniosExperiencia  Int?      // años de experiencia declarados
  cedulaUrl         String?
  cedulaStatus      String    @default("sin_enviar") // sin_enviar | pendiente | aprobado | rechazado
  cedulaNota        String?   // razón de rechazo (opcional)
  // ── Nuevas features avanzadas ──────────────────────────────────────────
  horario           Json?     // {"lun":{"activo":true,"inicio":"08:00","fin":"18:00"},...}
  portfolioUrls     String[]  // URLs de fotos de trabajos realizados
  instantBooking    Boolean   @default(false) // salta PENDIENTE → CONFIRMADO automáticamente
  reservasCompletadas Int     @default(0)     // contador desnormalizado de COMPLETADO
  tiempoRespuestaH  Float?    // promedio de horas hasta confirmar (actualizado por cron)
  totalViews        Int       @default(0)     // vistas al perfil público (incrementado en GET /providers/:id)
  tasaAceptacion    Float?    // % bookings confirmados (actualizado por cron diario)
  embedding         Unsupported("vector(1536)")?  // OpenAI text-embedding-3-small
  // ── Background check & voice onboarding ────────────────────────────────
  backgroundScore   Int?      // 0-100 composite score from voice interview + cedula
  backgroundData    Json?     // {references, workHistory, selfDeclaration, interviewAnswers}
  backgroundStatus  String    @default("pendiente") // pendiente | aprobado | rechazado | en_revision
  voiceOnboardingAt DateTime? // timestamp when voice interview was completed
  // ── Service packages ─────────────────────────────────────────────────────
  paquetes          Json?     // [{id,nombre,descripcion,precio,duracionHoras,incluye}]
  createdAt         DateTime  @default(now())

  bookings   Booking[]
  reviews    Review[]
  favoritos  Favorito[]
}

model Booking {
  id              String          @id @default(cuid())
  clienteId       String
  cliente         User            @relation("ClienteBookings", fields: [clienteId], references: [id])
  proveedorId     String
  proveedor       ProviderProfile @relation(fields: [proveedorId], references: [id])
  tipoServicio    String
  descripcion     String?
  fechaServicio   DateTime
  duracionHoras   Float           @default(2)
  precioTotal     Float
  comisionDutyJoy Float
  estado          EstadoBooking   @default(PENDIENTE)
  recurrencia     Recurrencia     @default(UNICA)     // frecuencia de repetición
  bookingPadreId  String?         // apunta al booking original (null si es el original)
  bookingPadre    Booking?        @relation("RecurrenciaBookings", fields: [bookingPadreId], references: [id])
  bookingsHijos   Booking[]       @relation("RecurrenciaBookings")
  motivoCancelacion String?       // razón de cancelación (opcional)
  fotos           String[]        // post-job photo URLs/base64 uploaded by provider
  // ── Service start code ────────────────────────────────────────────────────
  startCode         String?       // 6-digit code shown to client, entered by provider
  startCodeExpiry   DateTime?     // valid for 30 min after generation
  startCodeAttempts Int           @default(0)  // failed provider attempts (max 3)
  startCodeUsedAt   DateTime?     // set when provider verifies successfully
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  review    Review?
  disputas  Disputa[]
  mensajes  MensajeChat[]
}

enum Recurrencia {
  UNICA
  SEMANAL
  QUINCENAL
  MENSUAL
}

enum EstadoBooking {
  PENDIENTE
  CONFIRMADO
  EN_PROGRESO
  COMPLETADO
  CANCELADO
}

model Review {
  id           String          @id @default(cuid())
  bookingId    String          @unique
  booking      Booking         @relation(fields: [bookingId], references: [id])
  clienteId    String
  cliente      User            @relation("ClienteReviews", fields: [clienteId], references: [id])
  proveedorId  String
  proveedor    ProviderProfile @relation(fields: [proveedorId], references: [id])
  calificacion        Int      // 1 a 5
  comentario          String?
  respuestaProveedor  String?  // respuesta pública del proveedor a la reseña
  // ── Fraud detection ──────────────────────────────────────────────────────
  fraudScore          Float?   // 0.0 (clean) → 1.0 (likely fake)
  fraudFlags          String[] // detected patterns, e.g. ["texto_generico","primera_resena"]
  fraudCheckedAt      DateTime?
  fraudOculta         Boolean  @default(false) // admin hidó esta reseña
  createdAt           DateTime @default(now())
}

model Disputa {
  id              String   @id @default(cuid())
  bookingId       String
  booking         Booking  @relation(fields: [bookingId], references: [id])
  clienteId       String
  cliente         User     @relation(fields: [clienteId], references: [id])
  mensaje         String
  estado          String   @default("abierta")  // abierta | en_revision | resuelta | cerrada
  resolucion      String?  // nota de resolución por el admin
  resueltaPorId   String?  // userId del admin que resolvió
  // ── AI auto-resolution ──────────────────────────────────────────────────
  aiVeredicto     String?  // favor_cliente | favor_proveedor | compromiso
  aiConfianza     Float?   // 0.0 – 1.0
  aiRazonamiento  String?  // explicación del modelo
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([estado])
  @@index([bookingId])
  @@index([clienteId])
}

model MensajeChat {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  autorId     String
  autor       User     @relation("MensajesEnviados", fields: [autorId], references: [id])
  contenido   String
  leido       Boolean  @default(false)
  tipo        String   @default("texto") // texto | imagen | sistema
  createdAt   DateTime @default(now())

  @@index([bookingId, createdAt(sort: Asc)])
  @@index([autorId])
}

model Favorito {
  id          String          @id @default(cuid())
  clienteId   String
  cliente     User            @relation("ClienteFavoritos", fields: [clienteId], references: [id])
  proveedorId String
  proveedor   ProviderProfile @relation(fields: [proveedorId], references: [id])
  createdAt   DateTime        @default(now())

  @@unique([clienteId, proveedorId])
}

// ── CRM Tags ──────────────────────────────────────────────────────────────
model CrmTag {
  id          String   @id @default(cuid())
  nombre      String   @unique
  color       String   @default("#0ABFBC")
  descripcion String?
  createdAt   DateTime @default(now())

  asignaciones CrmTagAsignacion[]
}

model CrmTagAsignacion {
  id          String   @id @default(cuid())
  tagId       String
  tag         CrmTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asignadoPor String   // admin userId
  createdAt   DateTime @default(now())

  @@unique([tagId, userId])
  @@index([userId])
  @@index([tagId])
}

// ── Web Push Subscriptions ────────────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}
