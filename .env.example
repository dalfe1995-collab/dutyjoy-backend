# ── Base de datos (Supabase) ──────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio-minimo-64-chars"

# ── App ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
COMMISSION_RATE=0.15

# ── URLs (cambiar en producción) ──────────────────────────────────────────
FRONTEND_URL="https://app.dutyjoy.com"
BACKEND_URL="https://api.dutyjoy.com"
ALLOWED_ORIGINS="https://app.dutyjoy.com,https://dutyjoy.com"

# ── MercadoPago ───────────────────────────────────────────────────────────
# Obtener en: https://www.mercadopago.com.co/developers/panel/app
MP_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxxxxxxxxxx"
MP_PUBLIC_KEY="APP_USR-xxxxxxxxxxxxxxxxxxxx"
